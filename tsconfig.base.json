{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@door-in-four/types": ["packages/types/src"],
      "@door-in-four/shared": ["packages/shared/src"],
      "@door-in-four/pricing": ["packages/pricing/src"],
      "@door-in-four/config": ["packages/config/src"]
    }
  }
}
